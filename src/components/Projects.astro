---
import projects from "../data/projects.json";
---

<section id="projects" class="min-h-screen py-12 md:py-20">
  <div class="max-w-4xl mx-auto px-4">
    <div class="font-mono text-sm text-[#8b949e] mb-8">
      <span class="text-[#7ee787]">$</span> ls projects/
    </div>

    <h2 class="text-2xl font-mono font-bold text-[#c9d1d9] mb-8">Proyectos</h2>

    <div class="grid gap-4">
      {
        projects.map((project, index) => (
          <div class="font-mono border border-[#30363d] bg-[#161b22] p-4 hover:border-[#58a6ff] transition-colors group">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-[#8b949e] text-sm">[{index + 1}]</span>
                  <h3 class="text-[#58a6ff] font-bold">{project.name}</h3>
                </div>

                <p class="text-[#8b949e] text-sm mb-3">{project.description}</p>

                <div class="flex flex-wrap gap-2">
                  {project.tech.map((t) => (
                    <span class="text-xs px-2 py-1 bg-[#21262d] text-[#7ee787] rounded">
                      {t}
                    </span>
                  ))}
                </div>
              </div>

              <div class="flex flex-col gap-2 text-sm">
                {project.repoUrl && (
                  <a
                    href={project.repoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[#8b949e] hover:text-[#58a6ff] transition-colors"
                  >
                    ↗ repo
                  </a>
                )}
                {project.demoUrl && (
                  <a
                    href={project.demoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[#8b949e] hover:text-[#58a6ff] transition-colors"
                  >
                    ↗ demo
                  </a>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
