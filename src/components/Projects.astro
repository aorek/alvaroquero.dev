---
import projects from "../data/projects.json";
---

<section id="projects" class="min-h-screen py-12 md:py-20">
  <div class="max-w-4xl mx-auto px-4">
    <div class="font-mono text-sm text-secondary mb-8">
      <span class="text-accent-green">$</span> ls projects/
    </div>

    <h2 class="text-2xl font-mono font-bold text-primary mb-8">Proyectos</h2>

    <div class="grid gap-4">
      {
        projects.map((project, index) => (
          <div class="font-mono border border-theme p-4 hover:border-accent-blue transition-colors group" style="background-color: var(--bg-secondary)">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-secondary text-sm">[{index + 1}]</span>
                  <h3 class="text-accent-blue font-bold">{project.name}</h3>
                </div>

                <p class="text-secondary text-sm mb-3">{project.description}</p>

                <div class="flex flex-wrap gap-2">
                  {project.tech.map((t) => (
                    <span class="text-xs px-2 py-1 text-accent-green rounded" style="background-color: var(--bg-tertiary)">
                      {t}
                    </span>
                  ))}
                </div>
              </div>

              <div class="flex flex-col gap-2 text-sm">
                {project.repoUrl && (
                  <a
                    href={project.repoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-secondary hover:text-accent-blue transition-colors"
                  >
                    ↗ repo
                  </a>
                )}
                {project.demoUrl && (
                  <a
                    href={project.demoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-secondary hover:text-accent-blue transition-colors"
                  >
                    ↗ demo
                  </a>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
