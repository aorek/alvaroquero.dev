---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-gray-200 dark:border-gray-800 mt-auto">
  <div class="container-custom py-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- About section -->
      <div>
        <h3 class="font-bold text-lg mb-3">Álvaro Quero</h3>
        <p class="text-gray-600 dark:text-gray-400 text-sm">
          Desarrollador full stack apasionado por crear experiencias web modernas y eficientes.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="font-bold text-lg mb-3">Enlaces</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/about" class="link-primary">Sobre mí</a></li>
          <li><a href="/projects" class="link-primary">Proyectos</a></li>
          <li><a href="/blog" class="link-primary">Blog</a></li>
          <li><a href="/formation" class="link-primary">Formación</a></li>
        </ul>
      </div>

      <!-- Social links -->
      <div>
        <h3 class="font-bold text-lg mb-3">Contacto</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="mailto:aquerorodriguez@gmail.com" class="link-primary flex items-center gap-2">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
              </svg>
              Email
            </a>
          </li>
          <li>
            <a href="https://github.com/aorek" target="_blank" rel="noopener noreferrer" class="link-primary flex items-center gap-2">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd"></path>
              </svg>
              GitHub
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-8 pt-6 border-t border-gray-200 dark:border-gray-800 text-center text-sm text-gray-600 dark:text-gray-400">
      <p>© {currentYear} Álvaro Quero. Construido con <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="link-primary">Astro</a>.</p>
    </div>
