---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-[#30363d] py-8 mt-20">
  <div class="max-w-4xl mx-auto px-4">
    <div class="font-mono text-center text-sm text-[#8b949e]">
      <p class="mb-2">
        <span class="text-[#7ee787]">$</span> echo "¡Gracias por visitar!"
      </p>
      <p class="text-[#484f58]">
        © {currentYear} · Built with Astro
      </p>
    </div>
  </div>
</footer>
