---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-theme py-8 mt-20">
  <div class="max-w-4xl mx-auto px-4">
    <div class="font-mono text-center text-sm text-secondary">
      <p class="mb-2">
        <span class="text-accent-green">$</span> echo "¡Gracias por visitar!"
      </p>
      <p class="text-muted">
        © {currentYear} · Built with Astro
      </p>
    </div>
  </div>
</footer>
