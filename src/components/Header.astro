---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = '¡Hola! Soy Álvaro Quero',
  subtitle = 'Desarrollador full stack',
} = Astro.props;
---

<header class="py-16 md:py-24">
  <div class="container-custom">
    <h1 class="text-4xl md:text-6xl font-bold mb-4 bg-gradient-to-r from-primary-600 to-primary-400 bg-clip-text text-transparent">
      {title}
    </h1>
    <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-400">
      {subtitle}
    </p>
  </div>
</header>
